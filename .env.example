# ── aws_account_platform — environment ─────────────────────────────
# Copy to .env.local for local dev.

# Postgres runs NATIVE on the host (laptop & VPS). From inside Docker use host.docker.internal.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aws_account_platform"

# Auth.js
AUTH_SECRET="change-me-generate-a-long-random-string"

# Master key for encrypting stored AI provider keys (AES-256-GCM). 32 bytes, base64.
AI_KEY_ENCRYPTION_SECRET="change-me-32-byte-base64-key"

# App
NODE_ENV="development"
